{
  "name": "openclaw-handbook-export",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:handbook": "node scripts/render-handbook.mjs",
    "build:handbook:html": "node scripts/render-handbook.mjs --html-only",
    "build:handbook:pdf": "node scripts/render-handbook.mjs --pdf-only",
    "pdf:to-md": "python scripts/pdf_to_md.py",
    "handbook": "npm run build:handbook",
    "handbook:html": "npm run build:handbook:html",
    "handbook:pdf": "npm run build:handbook:pdf"
  },
  "dependencies": {
    "marked": "^16.3.0",
    "playwright-core": "^1.58.2"
  }
}
